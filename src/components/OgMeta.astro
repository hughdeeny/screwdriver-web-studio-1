---
import { OG_IMAGE_PATH, SITE_URL } from "../data/site";

interface Props {
  title: string;
  description: string;
  imageAlt?: string;
}

const { title, description, imageAlt = "Screwdriver Marketing" } = Astro.props;
const ogImageUrl = new URL(OG_IMAGE_PATH, SITE_URL).href;
const pageUrl = new URL(Astro.url.pathname, SITE_URL).href;
---

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:locale" content="en_AU" />
<meta property="og:url" content={pageUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1024" />
<meta property="og:image:height" content="537" />
<meta property="og:image:alt" content={imageAlt} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
