---
/**
 * Meta (Facebook) Pixel — base install (Screwdriver Marketing)
 *
 * Pixel ID: 1345042127603466
 * Override via .env: PUBLIC_META_PIXEL_ID=1345042127603466
 *
 * Installed in <head> via Layout.astro and LandingLayout.astro (every page).
 * PageView fires once per page load. ViewContent, quiz funnel events, and Lead
 * are tracked via src/lib/meta-pixel.ts in landing/quiz React components.
 */
const pixelId = import.meta.env.PUBLIC_META_PIXEL_ID || "1345042127603466";
---

<!-- Meta Pixel Code — ID 1345042127603466 -->
<script is:inline define:vars={{ pixelId }}>
  !(function (f, b, e, v, n, t, s) {
    if (f.fbq) return;
    n = f.fbq = function () {
      n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
    };
    if (!f._fbq) f._fbq = n;
    n.push = n;
    n.loaded = !0;
    n.version = "2.0";
    n.queue = [];
    t = b.createElement(e);
    t.async = !0;
    t.src = v;
    s = b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t, s);
  })(window, document, "script", "https://connect.facebook.net/en_US/fbevents.js");
  fbq("init", pixelId);
  fbq("track", "PageView");
</script>
<noscript>
  <img
    height="1"
    width="1"
    style="display:none"
    alt=""
    src={`https://www.facebook.com/tr?id=${pixelId}&ev=PageView&noscript=1`}
  />
</noscript>
<!-- End Meta Pixel Code -->
