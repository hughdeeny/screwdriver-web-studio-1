---
import Layout from "../layouts/Layout.astro";
import TrackedLink from "../components/TrackedLink.astro";
import LeadFlowVisual from "../components/LeadFlowVisual.astro";
import ContactForm from "../components/ContactForm.astro";
import {
  STRATEGY_MAIL,
  CONTACT_EMAIL,
  serviceCards,
  packages,
  faqs,
  industries,
  problemItems,
  solutionSteps,
  howItWorks,
  trackableActions,
  aiItems,
} from "../data/site";

const year = new Date().getFullYear();
---

<Layout>
  <div class="relative overflow-x-hidden">
    <div
      class="pointer-events-none fixed -left-40 top-20 h-[520px] w-[520px] rounded-full bg-accent/15 blur-[120px] animate-float-orb"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none fixed -right-32 bottom-0 h-[480px] w-[480px] rounded-full bg-signal/10 blur-[100px] animate-float-orb-delayed"
      aria-hidden="true"
    >
    </div>

    <header class="relative z-10 border-b border-[var(--border)] bg-bg-deep/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4 sm:px-6">
        <a href="#top" class="group flex items-center gap-2">
          <span
            class="font-display flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-accent to-accent-glow text-lg font-extrabold text-bg-deep shadow-lg shadow-accent/20 transition group-hover:scale-105"
            aria-hidden="true">S</span
          >
          <span class="font-display text-lg font-bold tracking-tight sm:text-xl">
            Screwdriver <span class="text-accent">Marketing</span>
          </span>
        </a>

        <nav class="hidden items-center gap-5 text-sm font-medium text-muted lg:flex" aria-label="Primary">
          <a href="#services" class="transition hover:text-cream">Services</a>
          <a href="#how-it-works" class="transition hover:text-cream">How it works</a>
          <a href="#packages" class="transition hover:text-cream">Packages</a>
          <a href="#faq" class="transition hover:text-cream">FAQ</a>
          <a href="#contact" class="transition hover:text-cream">Contact</a>
        </nav>

        <div class="flex items-center gap-2 sm:gap-3">
          <TrackedLink
            href={STRATEGY_MAIL}
            event="cta_click"
            cta="header_book_call"
            class="hidden min-h-[44px] items-center justify-center rounded-full bg-cream px-4 py-2.5 text-sm font-semibold text-bg-deep transition hover:bg-white sm:inline-flex"
          >
            Book a free strategy call
          </TrackedLink>

          <details class="relative lg:hidden">
            <summary
              class="flex min-h-[44px] cursor-pointer list-none items-center gap-2 rounded-full border border-[var(--border)] bg-bg-elevated px-4 py-2 text-sm font-medium text-cream"
            >
              <span class="sr-only">Open menu</span>
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"
                ></path>
              </svg>
              Menu
            </summary>
            <div
              class="absolute right-0 top-full z-20 mt-2 w-56 rounded-2xl border border-[var(--border)] bg-bg-elevated p-2 shadow-2xl"
            >
              <a href="#services" class="block min-h-[44px] rounded-xl px-4 py-3 text-sm hover:bg-white/5">Services</a>
              <a href="#how-it-works" class="block min-h-[44px] rounded-xl px-4 py-3 text-sm hover:bg-white/5"
                >How it works</a
              >
              <a href="#packages" class="block min-h-[44px] rounded-xl px-4 py-3 text-sm hover:bg-white/5">Packages</a>
              <a href="#faq" class="block min-h-[44px] rounded-xl px-4 py-3 text-sm hover:bg-white/5">FAQ</a>
              <TrackedLink
                href="#contact"
                event="cta_click"
                cta="mobile_nav_contact"
                class="block min-h-[44px] rounded-xl px-4 py-3 text-sm font-semibold text-accent hover:bg-white/5"
              >
                Contact
              </TrackedLink>
            </div>
          </details>
        </div>
      </div>
    </header>

    <main id="top">
      <section class="relative z-10 px-5 pb-20 pt-14 sm:px-6 sm:pb-28 sm:pt-20" aria-labelledby="hero-heading">
        <div class="mx-auto max-w-6xl">
          <div class="hero-animate grid gap-10 lg:grid-cols-2 lg:items-center lg:gap-12">
            <div class="flex max-w-xl flex-col gap-5 lg:max-w-none">
              <p
                class="inline-flex w-fit items-center gap-2 rounded-full border border-[var(--border)] bg-bg-elevated/80 px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-signal"
              >
                We help you find customers · You focus on the job
              </p>
              <h1
                id="hero-heading"
                class="font-display text-4xl font-extrabold leading-[1.08] tracking-tight sm:text-5xl md:text-5xl lg:text-6xl"
              >
                More customers,{" "}
                <span class="gradient-text animate-shimmer bg-gradient-to-r from-cream via-accent-glow to-signal">
                  less headaches
                </span>.
              </h1>
              <p class="text-lg leading-relaxed text-muted sm:text-xl">
                Screwdriver Marketing helps tradies, cleaners, landscapers, clinics, and local pros get found online
                and turn visitors into calls, quotes, and bookings — so you spend less time chasing leads and guessing
                what worked, and more time getting the job done. We handle the website, SEO pages, Google Business
                Profile, tracking, AI helpers, and ongoing care as one practical system.
              </p>
              <ul class="flex flex-col gap-2 text-sm text-cream/90 sm:text-base">
                <li class="flex gap-2">
                  <span class="text-signal" aria-hidden="true">✓</span>
                  We help bring the right enquiries in — you stay on the tools or with clients
                </li>
                <li class="flex gap-2">
                  <span class="text-signal" aria-hidden="true">✓</span>
                  Track calls, forms, and quote clicks — so you know what creates enquiries
                </li>
                <li class="flex gap-2">
                  <span class="text-signal" aria-hidden="true">✓</span>
                  Websites, SEO pages, AI helpers, Google Business Profile support, and ongoing care
                </li>
              </ul>
              <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:flex-wrap sm:items-center">
                <TrackedLink
                  href={STRATEGY_MAIL}
                  event="cta_click"
                  cta="hero_book_strategy_call"
                  class="inline-flex min-h-[52px] items-center justify-center rounded-full bg-gradient-to-r from-accent to-accent-glow px-8 text-base font-bold text-bg-deep shadow-lg shadow-accent/25 transition hover:brightness-110"
                >
                  Book a free strategy call
                </TrackedLink>
                <TrackedLink
                  href="#audit"
                  event="audit_request_click"
                  cta="hero_request_audit"
                  class="inline-flex min-h-[52px] items-center justify-center rounded-full border border-[var(--border)] px-8 text-base font-semibold text-cream transition hover:border-signal/50 hover:bg-white/5"
                >
                  Request a website audit
                </TrackedLink>
              </div>
              <p class="text-sm text-muted">
                <TrackedLink
                  href="#how-it-works"
                  event="cta_click"
                  cta="hero_see_system"
                  class="font-medium text-signal underline-offset-4 hover:underline"
                >
                  See how the system works
                </TrackedLink>
                — or scroll for the honest problem-and-solution breakdown.
              </p>
            </div>
            <LeadFlowVisual />
          </div>
        </div>
      </section>

      <section class="relative z-10 border-y border-[var(--border)] bg-bg-elevated/50 py-10" aria-label="Industries we help">
        <div class="mx-auto max-w-6xl px-5 sm:px-6">
          <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-muted">Who we work with</p>
          <div class="mt-5 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-muted">
            {
              industries.map((t) => (
                <span class="flex items-center gap-2">
                  <span class="h-1 w-1 shrink-0 rounded-full bg-signal" aria-hidden="true" />
                  {t}
                </span>
              ))
            }
          </div>
        </div>
      </section>

      <section id="problem" class="relative z-10 scroll-mt-24 px-5 py-20 sm:px-6 sm:py-24">
        <div class="mx-auto max-w-3xl">
          <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
            Most local businesses don't need more traffic first — they need to stop losing good leads.
          </h2>
          <p class="mt-4 text-lg text-muted">
            You're busy. If the digital side is unclear, slow, or disconnected from Google, you pay for it in wasted
            calls, confused customers, and marketing you can't trust.
          </p>
          <ul class="mt-8 space-y-3 text-cream/95">
            {
              problemItems.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section
        id="solution"
        class="relative z-10 scroll-mt-24 border-y border-[var(--border)] bg-bg-elevated/40 px-5 py-20 sm:px-6 sm:py-24"
      >
        <div class="mx-auto max-w-6xl">
          <h2 class="font-display max-w-3xl text-3xl font-bold tracking-tight sm:text-4xl">
            The fix is a simple system: get found, earn trust, make contact easy, then track what matters.
          </h2>
          <p class="mt-4 max-w-2xl text-lg text-muted">
            We're not selling "a beautiful website" as the prize. We tighten the digital system so more of the right
            people find you, believe you, and reach out — and you can see what's working. That way you're not the
            marketing department after hours; you're free to focus on getting the job done.
          </p>
          <ol class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
            {
              solutionSteps.map((s) => (
                <li class="glass rounded-2xl p-5">
                  <span class="font-display text-2xl font-extrabold text-accent/80">{s.step}</span>
                  <h3 class="font-display mt-2 text-lg font-bold text-cream">{s.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-muted">{s.text}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section id="services" class="relative z-10 scroll-mt-24 px-5 py-20 sm:px-6 sm:py-24">
        <div class="mx-auto max-w-6xl">
          <div class="max-w-2xl">
            <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">What we build and fix</h2>
            <p class="mt-3 text-lg text-muted">
              Same goal for every piece: more qualified enquiries, less admin — so you can focus on the work, not the
              website.
            </p>
          </div>
          <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {
              serviceCards.map((card) => (
                <article class="glass rounded-2xl border border-[var(--border)] p-6">
                  <h3 class="font-display text-lg font-bold text-cream">{card.title}</h3>
                  <p class="mt-3 text-sm leading-relaxed text-muted">{card.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section
        id="how-it-works"
        class="relative z-10 scroll-mt-24 border-y border-[var(--border)] px-5 py-20 sm:px-6 sm:py-24"
      >
        <div class="mx-auto max-w-6xl">
          <h2 class="font-display text-center text-3xl font-bold sm:text-4xl">How it works</h2>
          <p class="mx-auto mt-3 max-w-2xl text-center text-muted">
            Four practical steps — diagnose first, then build, track, and improve.
          </p>
          <ol class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
            {
              howItWorks.map((p, i) => (
                <li class="relative glass rounded-2xl p-6">
                  <span class="font-display text-3xl font-extrabold text-accent/40">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <h3 class="font-display mt-2 text-xl font-bold">{p.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-muted">{p.body}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section id="tracking" class="relative z-10 scroll-mt-24 px-5 py-20 sm:px-6 sm:py-24">
        <div class="mx-auto max-w-6xl lg:grid lg:grid-cols-2 lg:gap-12 lg:items-start">
          <div>
            <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
              Know what's actually creating enquiries
            </h2>
            <p class="mt-4 text-lg text-muted">
              Without basic tracking, you're flying blind — you can't tell whether Google, a flyer, or word-of-mouth
              drove that job. We wire up simple, privacy-conscious event tracking so you can see which parts of your
              site earn calls and forms.
            </p>
          </div>
          <ul class="mt-8 space-y-3 text-cream/95 lg:mt-0 glass rounded-2xl border border-[var(--border)] p-6">
            <li class="font-display text-sm font-bold uppercase tracking-wide text-accent">
              Trackable actions (examples)
            </li>
            {
              trackableActions.map((item) => (
                <li class="flex gap-2 text-sm">
                  <span class="text-signal" aria-hidden="true">→</span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section
        id="ai-tools"
        class="relative z-10 scroll-mt-24 border-y border-[var(--border)] bg-bg-elevated/40 px-5 py-20 sm:px-6 sm:py-24"
      >
        <div class="mx-auto max-w-6xl">
          <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl md:max-w-3xl">
            AI and automation — practical, not flashy
          </h2>
          <p class="mt-4 max-w-2xl text-lg text-muted">
            Used well, AI means less admin, faster replies, and cleaner systems — not chatbots that annoy your
            customers.
          </p>
          <ul class="mt-8 grid gap-4 sm:grid-cols-2">
            {
              aiItems.map((item) => (
                <li class="flex gap-3 rounded-xl border border-[var(--border)] bg-bg-deep/50 px-4 py-3 text-sm text-cream/95">
                  <span class="text-accent" aria-hidden="true">✓</span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section id="case-study" class="relative z-10 scroll-mt-24 px-5 py-20 sm:px-6 sm:py-24">
        <div class="mx-auto max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-widest text-accent">Example project</p>
          <h2 class="font-display mt-2 text-3xl font-bold sm:text-4xl">Green Theory Turf &amp; Garden Care</h2>
          <p class="mt-4 text-muted leading-relaxed">
            Early client project — we're careful not to overclaim results. Here's what we focused on together: a
            professional website launch, clearer service positioning, a stronger link between the Google Business Profile
            and the site, lead actions set up and ready to track, and a mobile-first path from search to quote request.
            Where Profile-driven traffic showed up early, we used it as one signal among others — the main win was a
            cleaner customer journey and a site that matched how they actually win work.
          </p>
          <TrackedLink
            href="#audit"
            event="quote_click"
            source="case_study_green_theory"
            class="mt-6 inline-flex min-h-[48px] items-center justify-center rounded-full border border-[var(--border)] px-6 text-sm font-semibold text-cream transition hover:border-signal/50 hover:bg-white/5"
          >
            Get more qualified enquiries
          </TrackedLink>
        </div>
      </section>

      <section
        id="packages"
        class="relative z-10 scroll-mt-24 border-y border-[var(--border)] bg-bg-elevated/40 px-5 py-20 sm:px-6 sm:py-24"
      >
        <div class="mx-auto max-w-6xl">
          <h2 class="font-display text-center text-3xl font-bold sm:text-4xl">Packages</h2>
          <p class="mx-auto mt-3 max-w-2xl text-center text-muted">
            Outcomes first. We'll confirm scope and pricing on a short call — no cookie-cutter surprises.
          </p>
          <div class="mt-12 grid gap-8 lg:grid-cols-3">
            {
              packages.map((pkg) => (
                <article class="flex flex-col rounded-2xl border border-[var(--border)] bg-bg-deep/60 p-6 sm:p-8">
                  <h3 class="font-display text-xl font-bold text-cream">{pkg.name}</h3>
                  <p class="mt-2 text-sm text-muted">{pkg.blurb}</p>
                  <ul class="mt-6 flex-1 space-y-2 text-sm text-cream/90">
                    {
                      pkg.outcomes.map((o) => (
                        <li class="flex gap-2">
                          <span class="text-signal" aria-hidden="true">✓</span>
                          {o}
                        </li>
                      ))
                    }
                  </ul>
                  <p class="mt-6 text-xs text-muted">{pkg.note}</p>
                  <TrackedLink
                    href="#audit"
                    event="quote_click"
                    pkg={pkg.name}
                    class="mt-4 inline-flex min-h-[48px] w-full items-center justify-center rounded-full border border-accent/40 bg-accent/10 text-sm font-semibold text-accent transition hover:bg-accent/20"
                  >
                    Discuss this option
                  </TrackedLink>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="faq" class="relative z-10 scroll-mt-24 px-5 py-20 sm:px-6 sm:py-24">
        <div class="mx-auto max-w-3xl">
          <h2 class="font-display text-3xl font-bold sm:text-4xl">FAQ</h2>
          <div class="mt-8 divide-y divide-[var(--border)] rounded-2xl border border-[var(--border)] bg-bg-elevated/30">
            {
              faqs.map((faq) => (
                <details class="px-5 py-4 first:rounded-t-2xl last:rounded-b-2xl">
                  <summary class="cursor-pointer list-none font-semibold text-cream marker:content-[''] [&::-webkit-details-marker]:hidden">
                    {faq.q}
                  </summary>
                  <p class="mt-3 pb-1 text-sm leading-relaxed text-muted">{faq.a}</p>
                </details>
              ))
            }
          </div>
        </div>
      </section>

      <section id="contact" class="relative z-10 scroll-mt-8 px-5 pb-24 sm:px-6" aria-labelledby="contact-heading">
        <div
          class="mx-auto max-w-6xl overflow-hidden rounded-[2rem] border border-[var(--border)] bg-gradient-to-br from-accent/15 via-bg-elevated to-signal-dim/15 p-px"
        >
          <div class="rounded-[2rem] bg-bg-deep/95 px-6 py-12 sm:px-10 sm:py-16">
            <div class="mx-auto max-w-2xl text-center">
              <h2 id="contact-heading" class="font-display text-3xl font-bold sm:text-4xl md:text-5xl">
                Want more of the right customers finding and contacting you?
              </h2>
              <p class="mt-4 text-lg text-muted">
                Let's look at your website, Google presence, and lead flow, then tighten the simplest things first — so
                more of the right people reach out while you stay focused on the job. No fluff, no obligation to
                proceed.
              </p>
              <div class="mt-8 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:flex-wrap">
                <TrackedLink
                  href={STRATEGY_MAIL}
                  event="cta_click"
                  cta="footer_book_strategy_call"
                  class="inline-flex min-h-[52px] flex-1 items-center justify-center rounded-full bg-gradient-to-r from-accent to-accent-glow px-8 text-base font-bold text-bg-deep shadow-lg shadow-accent/20 transition hover:brightness-110 sm:flex-none"
                >
                  Book a free strategy call
                </TrackedLink>
                <TrackedLink
                  href="#audit"
                  event="audit_request_click"
                  cta="footer_request_audit"
                  class="inline-flex min-h-[52px] flex-1 items-center justify-center rounded-full border border-[var(--border)] px-8 text-base font-semibold text-cream transition hover:border-signal/50 hover:bg-white/5 sm:flex-none"
                >
                  Request a website audit
                </TrackedLink>
              </div>
            </div>

            <div class="mx-auto mt-14 max-w-xl border-t border-[var(--border)] pt-12">
              <ContactForm />
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="relative z-10 border-t border-[var(--border)] px-5 py-12 sm:px-6">
      <div class="mx-auto flex max-w-6xl flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <span class="font-display text-lg font-bold">
            Screwdriver <span class="text-accent">Marketing</span>
          </span>
          <p class="mt-2 max-w-sm text-sm text-muted">
            We help you find customers and fix the digital side — so you can focus on getting the job done. More
            customers, less headaches.
          </p>
        </div>
        <div class="text-sm text-muted">
          <p class="font-medium text-cream">Get in touch</p>
          <TrackedLink
            href={`mailto:${CONTACT_EMAIL}`}
            event="email_click"
            location="footer"
            class="mt-2 block text-signal underline-offset-2 hover:underline"
          >
            {CONTACT_EMAIL}
          </TrackedLink>
        </div>
        <p class="text-sm text-muted sm:text-right">
          © {year} Screwdriver Marketing — Adelaide, Australia.
        </p>
      </div>
    </footer>
  </div>
</Layout>
