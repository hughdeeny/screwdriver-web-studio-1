---
import LandingLayout from "../../layouts/LandingLayout.astro";
import MetaPixelEvent from "../../components/MetaPixelEvent.astro";
---

<LandingLayout
  title="Thank you | Screwdriver Marketing"
  description="Thanks for completing the Reputation Health Check. We'll be in touch shortly."
>
  <MetaPixelEvent
    event="Lead"
    params={{
      content_name: "Landing Page Lead",
      content_category: "Free Audit / Enquiry",
    }}
  />

  <div class="theme-landing min-h-screen bg-page">
    <header class="mx-auto flex max-w-4xl items-center justify-between px-5 py-5 sm:px-8">
      <a href="/landing" class="group flex items-center gap-2">
        <span
          class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-accent to-accent-glow text-base font-extrabold text-white shadow-lg shadow-accent/20"
          aria-hidden="true">S</span
        >
        <span class="text-lg font-bold tracking-tight text-navy">
          Screwdriver <span class="text-accent">Marketing</span>
        </span>
      </a>
    </header>

    <main class="mx-auto max-w-2xl px-5 py-16 text-center sm:px-8 sm:py-24">
      <div class="rounded-2xl border border-border bg-card p-8 shadow-sm sm:p-12">
        <p class="text-sm font-semibold uppercase tracking-wide text-accent">Request received</p>
        <h1 class="mt-3 text-3xl font-bold text-navy sm:text-4xl">
          Thanks — your request has been received.
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          I&apos;ll review your details and get back to you shortly.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
          <a
            href="/landing"
            class="inline-flex min-h-[48px] items-center justify-center rounded-lg bg-accent px-6 py-3 font-semibold text-white transition hover:bg-accent-hover"
          >
            Back to landing page
          </a>
          <a
            href="/"
            class="inline-flex min-h-[48px] items-center justify-center rounded-lg border border-border bg-card px-6 py-3 font-semibold text-navy transition hover:bg-page"
          >
            Go to homepage
          </a>
        </div>
      </div>
    </main>
  </div>
</LandingLayout>
