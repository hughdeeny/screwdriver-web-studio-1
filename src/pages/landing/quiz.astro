---
import LandingLayout from "../../layouts/LandingLayout.astro";
import QuizPage from "../../components/landing/QuizPage";

// The native quiz shows dynamic results in-page on completion (see QuizForm.tsx)
// and fires the Meta Pixel "Lead" event at that point.
// If you replace this with a GoHighLevel or other embedded form that cannot fire
// the event itself, set that form's post-submit redirect to /landing/thank-you in
// the external provider's settings so the Lead event still fires there.
---

<LandingLayout
  title="Free Reputation Health Check | Screwdriver Marketing"
  description="Answer 15 quick questions and get your free Reputation Health Score with immediate recommendations."
>
  <QuizPage client:load />
</LandingLayout>
