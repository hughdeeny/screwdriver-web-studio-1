---
import "../styles/global.css";
import MetaPixel from "../components/MetaPixel.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Free Reputation Health Check | Screwdriver Marketing",
  description = "Take the free Reputation Health Check for local service businesses. Measure your Trust, Visibility, and Revenue — get immediate recommendations.",
} = Astro.props;
---

<!doctype html>
<html lang="en-AU" class="h-full antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a2744" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <MetaPixel />
  </head>
  <body class="theme-landing min-h-full font-sans">
    <slot />
    <script
      is:inline
      src="https://link.msgsndr.com/js/external-tracking.js"
      data-tracking-id="tk_3f252748a43142b881d6311214236a7e"
    ></script>
  </body>
</html>
